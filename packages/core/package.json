{
  "name": "@omnicross/core",
  "version": "0.1.2",
  "description": "Omnicross LLM serving core — provider dispatch, completion pipeline, transformers, and the provider proxy.",
  "license": "MIT",
  "author": "Sayo (https://github.com/Dumoedss)",
  "homepage": "https://github.com/Dumoedss/omnicross#readme",
  "keywords": [
    "omnicross",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "proxy",
    "router",
    "completion",
    "transformer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dumoedss/omnicross.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@omnicross/contracts": "^0.1.0",
    "jsdom": "^24.1.3",
    "socks": "^2.8.3",
    "turndown": "^7.2.2",
    "undici": "^6.21.1"
  }
}
