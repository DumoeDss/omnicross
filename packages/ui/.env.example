# Omnicross UI — daemon connection config.
# Copy to `.env` (or `.env.local`) and adjust as needed.

# Daemon admin API base URL. LEAVE UNSET for the defaults:
#  - browser (dev server or daemon-served /ui): same-origin — in dev the Vite
#    proxy forwards /admin/* to http://127.0.0.1:8766 (no CORS involved),
#  - Tauri shell: http://127.0.0.1:8766 via the native HTTP plugin.
# Only set this for unusual setups (e.g. the Tauri shell against a remote
# daemon). Do NOT set it to an absolute URL for browser dev — the daemon sends
# no CORS headers, so cross-origin browser calls fail by design.
#VITE_DAEMON_BASE_URL=

# Where the DEV PROXY forwards /admin/* (browser dev only; default below).
#VITE_DAEMON_PROXY_TARGET=http://127.0.0.1:8766

# Optional admin bearer token. Leave UNSET for a token-free loopback daemon
# (the default dev setup). When the daemon's config.json sets `admin.token`,
# put the same value here so the app sends `Authorization: Bearer <token>`.
VITE_DAEMON_ADMIN_TOKEN=
