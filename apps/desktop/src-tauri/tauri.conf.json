{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omnicross",
  "version": "0.1.3",
  "identifier": "io.github.dumoedss.omnicross",
  "build": {
    "frontendDist": "../../../packages/ui/dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "npm --prefix ../../packages/ui run dev",
    "beforeBuildCommand": "npm --prefix ../../packages/ui run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Omnicross Control Panel",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8766 http://localhost:8766"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "daemon-runtime"
    ]
  }
}
